{
  "name": "restricted-areas-data",
  "version": "0.0.0",
  "private": true,
  "description": "Data pipeline: convert ProtectedSeas Navigator GeoJSON into regional (ocean-basin) FlatGeobuf extracts published as GitHub Release assets for signalk-restricted-areas.",
  "type": "module",
  "scripts": {
    "format": "prettier --write \"bin/**/*.mjs\" \"test/**/*.mjs\"",
    "lint": "eslint \"bin/**/*.mjs\" \"test/**/*.mjs\"",
    "test": "vitest run",
    "build:all": "npm run lint && npm run test"
  },
  "keywords": [
    "protectedseas",
    "navigator",
    "marine",
    "flatgeobuf",
    "signalk"
  ],
  "author": "Dirk Wahrheit",
  "license": "Apache-2.0",
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "@turf/bbox": "^7.1.0",
    "@turf/simplify": "^7.1.0",
    "stream-json": "^1.8.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "eslint": "^10.4.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.2.1",
    "prettier": "^3.4.2",
    "vitest": "^4.1.8"
  }
}
